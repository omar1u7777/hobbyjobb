{
  "info": {
    "_postman_id": "hobbyjobb-s1-collection",
    "name": "HobbyJobb S1 – Auth & Payments",
    "description": "Postman collection för S1 Omar Alhaek – Auth och Payments endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MTEsImVtYWlsIjoiZGVtby5hbWluQGhvYmJ5am9iYi5zZSIsImlzX2FkbWluIjpmYWxzZSwiaWF0IjoxNzc3NjQ1MjA5LCJleHAiOjE3NzgyNTAwMDl9.9pDgX4vMKnTJQmy9D18m5mWTXilm2NeIFS4U0av1Sys",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"location\": \"Kristianstad\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo.amin@hobbyjobb.se\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["pm.collectionVariables.set('token', pm.response.json().data?.token || pm.response.json().token);"]
            }
          }]
        },
        {
          "name": "GetMe",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{baseUrl}}/auth/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Checkout",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{baseUrl}}/payments/checkout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": 50,\n  \"amount\": 1\n}"
            }
          }
        },
        {
          "name": "Get Payment History",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": "{{baseUrl}}/payments/history"
          }
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{baseUrl}}/payments/confirm",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentIntentId\": \"pi_test_123\"\n}"
            }
          }
        },
        {
          "name": "Release Escrow",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{baseUrl}}/payments/release/50",
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "Create Boost",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{baseUrl}}/payments/boost",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": 50,\n  \"package\": \"standard\",\n  \"durationHours\": 48\n}"
            }
          }
        },
        {
          "name": "Confirm Boost",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{baseUrl}}/payments/boost/confirm",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentIntentId\": \"pi_boost_123\"\n}"
            }
          }
        },
        {
          "name": "Webhook (Stripe – development)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": "{{baseUrl}}/payments/webhook",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"pi_test_123\",\n      \"amount\": 50000,\n      \"currency\": \"sek\",\n      \"metadata\": {\n        \"jobId\": \"1\",\n        \"payerId\": \"1\",\n        \"payeeId\": \"2\"\n      }\n    }\n  }\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/health"
          }
        }
      ]
    }
  ]
}
