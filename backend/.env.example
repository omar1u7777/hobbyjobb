# Server
PORT=5000
NODE_ENV=development

# Databas (lokalt: postgresql://user:password@localhost:5432/hobbyjobb_dev)
DATABASE_URL=postgresql://user:password@localhost:5432/hobbyjobb_dev

# JWT (använd ett långt, slumpmässigt värde i produktion)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Hobbyverksamhet granser
HOBBY_ANNUAL_LIMIT=30000
HOBBY_WARNING_THRESHOLD=25000
HOBBY_MONTHLY_JOB_LIMIT=20

# Stripe Connect (hämtas från https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_FEE_PERCENT=8

# CORS (kommaseparerat, inga mellanslag)
ALLOWED_ORIGINS=http://localhost:5173
